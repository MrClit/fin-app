# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# edenred scraper — sesión Playwright con cookies válidas, nunca commitear
scripts/storage-state.json
scripts/storage-state.json.*

# sabadell scraper — sesión/perfil Playwright y volcados de investigación
scripts/sabadell-storage-state.json
scripts/sabadell-storage-state.json.*
scripts/.sabadell-userdata/
scripts/.sabadell-*.local.*

# serwist — service worker generado en build
public/sw.js
public/sw.js.map
