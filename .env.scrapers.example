# Producción de scrapers (launchd local → POST a Vercel).
#
# Lo cargan SOLO los scripts scrape:* vía `node --env-file*=.env.scrapers`.
# Next NUNCA lo auto-carga (a diferencia de .env.local / .env.production.local),
# por eso el nombre es neutro. Copia este fichero a `.env.scrapers` y rellena los
# valores reales. El fichero `.env.scrapers` está gitignored: lleva credenciales.

# Destino del POST: URL de PRODUCCIÓN en Vercel, sin barra final. NUNCA localhost.
APP_URL=https://fin-app-tawny.vercel.app

# Edenred
EDENRED_WEBHOOK_SECRET=    # auth del POST a /api/edenred — mismo valor que en Vercel (openssl rand -hex 32)
EDENRED_USER=              # email de edenred.es (solo para scrape:edenred:login)
EDENRED_PASS=              # contraseña de edenred.es (solo para scrape:edenred:login)

# Sabadell VISA (#147)
SABADELL_VISA_WEBHOOK_SECRET=   # auth del POST a /api/sabadell-visa — mismo valor que en Vercel (openssl rand -hex 32)
SABADELL_USER=             # DNI/NIF de acceso a BS Online (solo para scrape:sabadell-visa:login)
SABADELL_PASS=             # PIN de 8 dígitos de BS Online (solo para scrape:sabadell-visa:login)

# Flags opcionales de control (normalmente NO se ponen aquí):
# - EDENRED_CRON / SABADELL_CRON: "1" activa el guard del marker diario. Lo inyecta
#   el plist de launchd (install-launchd.sh), no este fichero.
# - EDENRED_SKIP_MARKER / SABADELL_SKIP_MARKER: lo activan los scripts scrape:*:force.
# - SABADELL_CARDS: last4 de tarjetas objetivo, separadas por coma (por defecto "4014,5011").
# - SABADELL_DEBUG / SABADELL_DRY_RUN: "1" para depuración / no escribir.
# - SABADELL_LOGIN_URL: override de la URL de login de BS Online.
